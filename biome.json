{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": false },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUndeclaredVariables": "error",
        "noUnusedVariables": "warn",
        "noInnerDeclarations": "warn"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "off",
        "noGlobalIsNan": "warn",
        "noRedundantUseStrict": "warn"
      },
      "style": {
        "useConst": "warn",
        "noVar": "warn",
        "useTemplate": "warn",
        "useNumberNamespace": "warn",
        "noUselessElse": "warn",
        "useSingleVarDeclarator": "warn",
        "noParameterAssign": "warn"
      },
      "complexity": {
        "noForEach": "off",
        "useArrowFunction": "warn",
        "useOptionalChain": "warn",
        "useLiteralKeys": "warn",
        "noUselessThisAlias": "warn"
      },
      "performance": {
        "noDelete": "warn"
      }
    }
  },
  "javascript": {
    "globals": [
      "window",
      "document",
      "console",
      "setTimeout",
      "clearTimeout",
      "setInterval",
      "clearInterval",
      "requestAnimationFrame",
      "cancelAnimationFrame",
      "requestIdleCallback",
      "cancelIdleCallback",
      "fetch",
      "localStorage",
      "sessionStorage",
      "history",
      "location",
      "navigator",
      "matchMedia",
      "getComputedStyle",
      "CSS",
      "Node",
      "NodeFilter",
      "MutationObserver",
      "IntersectionObserver",
      "ResizeObserver",
      "CustomEvent",
      "HTMLElement",
      "Element",
      "Event",
      "KeyboardEvent",
      "MouseEvent",
      "TouchEvent",
      "PointerEvent",
      "WheelEvent",
      "FocusEvent",
      "InputEvent",
      "DragEvent",
      "ClipboardEvent",
      "HashChangeEvent",
      "PopStateEvent",
      "StorageEvent",
      "MediaQueryListEvent",
      "DOMParser",
      "XMLSerializer",
      "URL",
      "URLSearchParams",
      "Blob",
      "File",
      "FileReader",
      "FormData",
      "Headers",
      "Request",
      "Response",
      "AbortController",
      "Image",
      "Audio",
      "Map",
      "Set",
      "WeakMap",
      "WeakSet",
      "Promise",
      "performance",
      "screen",
      "queueMicrotask",
      "structuredClone",
      "TextEncoder",
      "TextDecoder",
      "atob",
      "btoa",
      "crypto",
      "WebSocket",
      "EventSource",
      "Worker",
      "DocumentFragment",
      "Text",
      "Comment",
      "Range",
      "Bengal",
      "BengalUtils",
      "BengalTheme",
      "BengalTabs",
      "BengalTOC",
      "BengalTracks",
      "lunr",
      "mermaid",
      "Tabulator",
      "d3",
      "katex",
      "BENGAL_LAZY_ASSETS",
      "BENGAL_ICONS",
      "BENGAL_THEME_DEFAULTS"
    ]
  },
  "files": {
    "include": ["src/bengal_themes/chirp_theme/assets/js/**/*.js"],
    "ignore": [
      "**/vendor/**",
      "**/*.min.js",
      "node_modules/**",
      "site/**",
      "_site/**",
      "dist/**",
      "build/**"
    ]
  }
}
