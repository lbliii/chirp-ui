{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "examples/component-showcase/Dockerfile"
  },
  "deploy": {
    "startCommand": "python examples/component-showcase/app.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
